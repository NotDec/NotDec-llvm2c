{
  "algorithms": ["structured-sailr"],
  "opts": ["O2"],
  "clang_args": ["-Wno-implicit-function-declaration"],
  "notdec_args": [],
  "oracle": {
    "regex_absent": [
      "goto structured_block_([0-9]+);\\n\\s*structured_block_\\1:",
      "goto structured_block_[0-9]+;\\n\\s*while \\(1\\)",
      "goto structured_block_[0-9]+;\\n\\s*if \\(",
      "^    break;$",
      "^    continue;$",
      "return [^;]+;\\n\\s*(?!\\}|//|[A-Za-z_][A-Za-z0-9_]*:)(?:[A-Za-z_]|while|if|switch|do)",
      "continue;\\n\\s*(?!\\}|//|[A-Za-z_][A-Za-z0-9_]*:)(?:[A-Za-z_]|while|if|switch|do|goto)",
      "if \\([^\\n]+\\) \\{\\n\\s*break;\\n\\s*\\} else \\{\\n\\s*continue;\\n\\s*\\}\\n\\s*(?!\\}|//|[A-Za-z_][A-Za-z0-9_]*:)(?:[A-Za-z_]|while|if|switch|do|goto)"
    ]
  },
  "cases": [
    {
      "name": "diamond_if_else",
      "source": "cases/001_diamond_if_else.c",
      "oracle": {
        "contains": ["if (", "left_path();", "right_path();", "sink("],
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "loop_break_continue",
      "source": "cases/002_loop_break_continue.c",
      "oracle": {
        "contains": ["while (", "break;", "continue;", "sink("],
        "min_counts": {"break": 1, "continue": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "switch_cluster",
      "source": "cases/003_switch_cluster.c",
      "oracle": {
        "contains": [
          "switch (",
          "case 1:",
          "case 2:",
          "case 7:",
          "default:",
          "one_path();",
          "two_path();",
          "seven_path();",
          "default_path();"
        ],
        "max_counts": {"goto": 0},
        "min_counts": {"switch": 1}
      }
    },
    {
      "name": "tail_merge_return",
      "source": "cases/004_tail_merge_return.c",
      "oracle": {
        "contains": ["return"],
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "nested_loop_switch",
      "source": "cases/005_nested_loop_switch.c",
      "oracle": {
        "contains": ["while (", "switch (", "case 0:", "case 1:", "break;", "continue;"],
        "max_counts": {"goto": 0, "while": 1},
        "min_counts": {"switch": 1}
      }
    },
    {
      "name": "early_return_chain",
      "source": "cases/006_early_return_chain.c",
      "oracle": {
        "contains": ["if (", "return"],
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "nested_loop_break_continue",
      "source": "cases/007_nested_loop_break_continue.c",
      "xfail": true,
      "xfail_exact": [
        "missing pattern '^\\\\s+sink\\\\('",
        "expected goto<=0"
      ],
      "oracle": {
        "contains": ["while (", "break;", "continue;", "sink("],
        "regex_contains": ["^\\s+sink\\("],
        "min_counts": {"break": 1, "continue": 1, "while": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "guarded_loop_skip",
      "source": "cases/008_guarded_loop_skip.c",
      "oracle": {
        "contains": ["while (", "sink(", "return"],
        "min_counts": {"while": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "loop_switch_latch",
      "source": "cases/009_loop_switch_latch.c",
      "oracle": {
        "contains": ["switch (", "case 0:", "case 1:", "return"],
        "min_counts": {"switch": 1, "while": 1},
        "max_counts": {"goto": 0, "while": 1}
      }
    },
    {
      "name": "loop_two_returns",
      "source": "cases/010_loop_two_returns.c",
      "oracle": {
        "contains": ["while (", "return"],
        "min_counts": {"while": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "tail_early_return",
      "source": "cases/011_tail_early_return.c",
      "oracle": {
        "contains": ["while (", "return"],
        "min_counts": {"while": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "switch_continue_latch",
      "source": "cases/012_switch_continue_latch.c",
      "oracle": {
        "contains": ["switch (", "case 0:", "case 1:", "sink(", "return"],
        "regex_contains": ["^\\s+sink\\("],
        "regex_absent": ["default:\\n\\s*\\{\\n\\s*continue;\\n\\s*\\}"],
        "min_counts": {"switch": 1, "while": 1},
        "max_counts": {"goto": 0, "while": 1}
      }
    },
    {
      "name": "loop_switch_shared_latch",
      "source": "cases/013_loop_switch_shared_latch.c",
      "oracle": {
        "contains": ["switch (", "case 0:", "case 1:", "case 7:", "sink(", "return"],
        "min_counts": {"switch": 1, "while": 1},
        "max_counts": {"goto": 0, "while": 1}
      }
    },
    {
      "name": "switch_early_return",
      "source": "cases/014_switch_early_return.c",
      "oracle": {
        "contains": ["switch (", "case 0:", "case 1:", "case 2:", "default:", "return", "sink("],
        "min_counts": {"switch": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "switch_shared_return_tail",
      "source": "cases/015_switch_shared_return_tail.c",
      "oracle": {
        "contains": ["switch (", "case 1:", "case 2:", "default:", "sink(", "return"],
        "min_counts": {"switch": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "nested_loop_break_only",
      "source": "cases/016_nested_loop_break_only.c",
      "oracle": {
        "contains": ["while (", "break;", "sink(", "return"],
        "min_counts": {"while": 1, "break": 1},
        "max_counts": {"goto": 0}
      }
    },
    {
      "name": "switch_continue_only_latch",
      "source": "cases/017_switch_continue_only_latch.c",
      "oracle": {
        "contains": ["switch (", "case 0:", "case 1:", "continue;", "return"],
        "min_counts": {"switch": 1, "while": 1},
        "max_counts": {"goto": 0, "while": 1}
      }
    }
  ]
}


#include "notdec-backends/Structuring/StructurerRegistry.h"

struct StructurerChoice {
  std::string_view Name =
      ::notdec::backend::structuring::DefaultStructurerName;

  friend bool operator==(const StructurerChoice &Lhs,
                         const StructurerChoice &Rhs) {
    return Lhs.Name == Rhs.Name;
  }
};

namespace llvm::cl {
template <> struct OptionValue<StructurerChoice> final
    : OptionValueCopy<StructurerChoice> {
  using WrapperType = StructurerChoice;

  OptionValue() = default;
  OptionValue(const StructurerChoice &V) { this->setValue(V); }

  OptionValue<StructurerChoice> &operator=(const StructurerChoice &V) {
    this->setValue(V);
    return *this;
  }
};
} // namespace llvm::cl

static cl::OptionCategory NotdecLLVM2CCat("NotDec-llvm2c Options");

static cl::opt<bool>
    enableColor("debug-color",
                cl::desc("Enable color output for things like CFG dump."),
                cl::init(false), cl::cat(NotdecLLVM2CCat));
static cl::opt<StructurerChoice> Algo(
    "algo",
    cl::desc("Structuring algorithm name."),
    cl::init(StructurerChoice{}), cl::cat(NotdecLLVM2CCat));
static bool InitAlgoChoices = []() {
  auto &Parser = Algo.getParser();
  Parser.addLiteralOption(
      "goto", StructurerChoice{"goto"}, "alias of structured-goto");
  Parser.addLiteralOption("structured-goto", StructurerChoice{"goto"},
                          "shared structuring goto adapter");
  Parser.addLiteralOption("structured-phoenix", StructurerChoice{"phoenix"},
                          "shared structuring phoenix reducer");
  Parser.addLiteralOption("structured-sailr", StructurerChoice{"sailr"},
                          "shared structuring SAILR adapter");
  return true;
}();
static cl::opt<bool>
    noDemoteSSA("no-demote-ssa",
                cl::desc("Disable SSA demotion passes. Eliminate all phi nodes "
                         "before enabling this."),
                cl::init(false), cl::cat(NotdecLLVM2CCat));
static cl::opt<bool>
    filterUnusedDefinitions(
        "filter-unused-definitions",
        cl::desc("Only print referenced type declarations and definitions."),
        cl::init(false), cl::cat(NotdecLLVM2CCat));

::notdec::llvm2c::Options getLLVM2COptions() {
  ::notdec::llvm2c::Options Opts = {
      .noDemoteSSA = noDemoteSSA,
      .enableColor = enableColor,
      .filterUnusedDefinitions = filterUnusedDefinitions,
      .structurer = std::string(Algo.getValue().Name),
      .workDir = "",
  };
  return Opts;
}
